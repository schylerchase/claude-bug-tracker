#!/usr/bin/env bash
# PreToolUse hook for claude-bug-tracker plugin
# Checks git commit commands for fix() convention and fragile area warnings

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Only run in git repos
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    cat <<'EOF'
{}
EOF
    exit 0
fi

# Read tool input from stdin
input=$(cat 2>/dev/null || echo "")

# Check if this is a git commit command
if ! echo "$input" | grep -q "git commit"; then
    cat <<'EOF'
{}
EOF
    exit 0
fi

# Extract commit message from -m flag
commit_msg=$(echo "$input" | grep -oP '(?<=-m\s["\x27])[^"\x27]+' 2>/dev/null || \
             echo "$input" | grep -oP '(?<=-m\s")[^"]+' 2>/dev/null || \
             echo "$input" | sed -n "s/.*-m ['\"]\\(.*\\)['\"].*/\\1/p" 2>/dev/null || \
             echo "")

# If we can't extract the message (heredoc etc), try a broader match
if [ -z "$commit_msg" ]; then
    # Check if it looks like a fix commit from any context
    if echo "$input" | grep -qi "fix\|bug\|patch\|repair\|resolve"; then
        commit_msg="(fix-related commit detected)"
    else
        cat <<'EOF'
{}
EOF
        exit 0
    fi
fi

warnings=""

# Check if commit looks like a fix but doesn't use fix() convention
is_fix=false
if echo "$commit_msg" | grep -qi "fix\|bug\|patch\|repair\|resolve"; then
    is_fix=true
fi

if $is_fix && ! echo "$commit_msg" | grep -q "^fix("; then
    # Suggest scope from staged files
    staged_files=$(git diff --cached --name-only 2>/dev/null || echo "")
    suggested_scope="general"

    if echo "$staged_files" | grep -q "^src/gui/"; then
        suggested_scope="gui"
    elif echo "$staged_files" | grep -q "^src/core/"; then
        suggested_scope="core"
    elif echo "$staged_files" | grep -q "^src/web/"; then
        suggested_scope="web"
    elif echo "$staged_files" | grep -q "^src/api/"; then
        suggested_scope="api"
    elif echo "$staged_files" | grep -q "^src/cli/"; then
        suggested_scope="cli"
    elif echo "$staged_files" | grep -q "^tests/"; then
        suggested_scope="tests"
    fi

    warnings="This looks like a bug fix. Consider using: fix(${suggested_scope}): <description>"
fi

# Check if any staged files are in fragile areas
fragile_warnings=""
if [ -f "${PLUGIN_ROOT}/scripts/check-fragile.sh" ]; then
    staged_files=$(git diff --cached --name-only 2>/dev/null || echo "")
    if [ -n "$staged_files" ]; then
        fragile_warnings=$(echo "$staged_files" | bash "${PLUGIN_ROOT}/scripts/check-fragile.sh" 2>/dev/null || echo "")
    fi
fi

if [ -n "$fragile_warnings" ]; then
    if [ -n "$warnings" ]; then
        warnings="${warnings}\n${fragile_warnings}"
    else
        warnings="$fragile_warnings"
    fi
fi

# Output result
if [ -n "$warnings" ]; then
    # Escape for JSON
    warnings_escaped=$(echo -e "$warnings" | sed 's/\\/\\\\/g; s/"/\\"/g; s/$/\\n/' | tr -d '\n' | sed 's/\\n$//')
    cat <<EOF
{
  "additional_context": "${warnings_escaped}"
}
EOF
else
    cat <<'EOF'
{}
EOF
fi

exit 0
